#!/bin/sh
#
# Normalize the Windows-only "clean" command in staged package.json files to
# its Unix equivalent, so the same package.json works regardless of the OS the
# author committed from. POSIX sh: runs on Linux, macOS, and Git Bash.

set -eu

cd "$(git rev-parse --show-toplevel)"

to_replace='rd /s /q dist>nul 2>&1|echo.>nul'
replacement='rm -rf ./dist/*'

# Inspect only the package.json files staged for THIS commit (added/copied/
# modified). The old hook diffed HEAD^..HEAD, i.e. the *previous* commit.
git diff --cached --name-only --diff-filter=ACM \
	| grep -E '(^|/)package\.json$' \
	| while IFS= read -r file; do
		[ -f "$file" ] || continue
		# Fixed-string match for detection avoids regex surprises.
		grep -qF "$to_replace" "$file" || continue

		# Portable in-place edit: GNU and BSD sed disagree on -i, so write to a
		# temp file and move it back. '#' delimiter avoids escaping the '/'s.
		tmp=$(mktemp)
		sed "s#$to_replace#$replacement#g" "$file" >"$tmp" && mv "$tmp" "$file"

		# NOTE: this re-stages the whole file, including any other unstaged
		# edits to it. Keep unrelated package.json edits out of such a commit.
		git add "$file"
		echo "Normalized clean command in $file"
	done
